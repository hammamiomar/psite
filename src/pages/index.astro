---
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { buttonVariants } from '@/components/ui/button'
import WorkTimer from '@/components/ui/work-timer'
import Layout from '@/layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
---

<Layout>
  <PageHead slot="head" title="About" />

  <section class="prose prose-neutral dark:prose-invert max-w-none">
    <p>
      Building <Link href="/blog/letting-computers-dance">hambajuba2ba</Link>
      — a music visualizer that steers SDXL-Turbo's generation using
      Sparse Autoencoder features mapped to audio. 50 FPS on a single consumer GPU.
      Music visualization as interpretability research.
    </p>

    <div class="not-prose my-6 flex gap-4">
      <a
        href="/cv/ResumeHammamiOmar.pdf"
        download
        class={buttonVariants({ variant: 'default' })}
      >
        <Icon name="lucide:download" class="mr-2 h-4 w-4" />
        Download CV
      </a>
      <Link href="/projects" class={buttonVariants({ variant: 'outline' })}>
        View Projects
      </Link>
    </div>
  </section>

  <WorkTimer client:load className="my-8" />

</Layout>
