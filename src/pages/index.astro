---
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import WorkTimer from '@/components/ui/work-timer'
import Layout from '@/layouts/Layout.astro'
---

<Layout>
  <PageHead slot="head" title="About" />

  <section class="prose prose-neutral dark:prose-invert max-w-none">
    <p>
      Building <Link href="/blog/letting-computers-dance">hambajuba2ba</Link>
      — a music visualizer that lets you see what's inside a diffusion model.
    </p>
    <p>
      Currently working on <Link href="/blog/subspacelens">SubspaceLens</Link>
      — measuring subspace geometry in diffusion transformers using MCR²
      instead of sparse autoencoders. If any of this sounds interesting, say hi.
    </p>

  </section>

  <nav class="not-prose my-8 font-mono text-sm">
    <div class="text-muted-foreground mb-3 text-xs tracking-widest uppercase">explore</div>
    <div class="space-y-2">
      <a href="/blog" class="group flex items-baseline gap-3 py-1.5 transition-colors hover:text-foreground">
        <span class="text-muted-foreground group-hover:text-primary transition-colors">~/</span>
        <span class="font-medium">blog</span>
        <span class="text-muted-foreground text-xs hidden sm:inline">— interpretability, music vis, ml</span>
      </a>
      <a href="/projects" class="group flex items-baseline gap-3 py-1.5 transition-colors hover:text-foreground">
        <span class="text-muted-foreground group-hover:text-primary transition-colors">~/</span>
        <span class="font-medium">projects</span>
        <span class="text-muted-foreground text-xs hidden sm:inline">— hambajuba2ba, SubspaceLens</span>
      </a>
      <a href="/recipes" class="group flex items-baseline gap-3 py-1.5 transition-colors hover:text-foreground">
        <span class="text-muted-foreground group-hover:text-primary transition-colors">~/</span>
        <span class="font-medium">recipes</span>
        <span class="text-muted-foreground text-xs hidden sm:inline">— because why not</span>
      </a>
    </div>
    <div class="mt-4">
      <a
        href="/cv/ResumeHammamiOmar.pdf"
        download
        class="group flex items-baseline gap-3 py-1.5 transition-colors hover:text-foreground"
      >
        <span class="text-muted-foreground group-hover:text-primary transition-colors">~/</span>
        <span class="font-medium">cv</span>
        <span class="text-muted-foreground text-xs hidden sm:inline">— pdf download</span>
      </a>
    </div>
  </nav>

  <WorkTimer client:load className="my-8" />

</Layout>
