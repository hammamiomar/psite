---
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { buttonVariants } from '@/components/ui/button'
import WorkTimer from '@/components/ui/work-timer'
import Layout from '@/layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
---

<Layout>
  <PageHead slot="head" title="About" />

  <section class="prose prose-neutral dark:prose-invert max-w-none">
    <p>
      Building <Link href="/blog/letting-computers-dance">hambajuba2ba</Link>
      — a music visualizer that steers SDXL-Turbo's generation using
      Sparse Autoencoder features mapped to audio. 50 FPS on a single consumer GPU.
      Music visualization as interpretability research.
    </p>

    <div class="not-prose my-6 flex gap-4">
      <a
        href="/cv/ResumeHammamiOmar.pdf"
        download
        class={buttonVariants({ variant: 'default' })}
      >
        <Icon name="lucide:download" class="mr-2 h-4 w-4" />
        Download CV
      </a>
      <Link href="/projects" class={buttonVariants({ variant: 'outline' })}>
        View Projects
      </Link>
    </div>
  </section>

  <WorkTimer client:load className="my-8" />

  <section class="my-8 rounded-lg border border-border bg-secondary/30 p-6 text-center">
    <h3 class="mb-2 text-lg font-medium text-foreground">
      Get notified when hambajuba launches
    </h3>
    <p class="mb-4 text-sm text-muted-foreground">
      Drop your email — I'll let you know when the desktop app is ready.
    </p>
    <form
      action="https://formspree.io/f/YOUR_FORM_ID"
      method="POST"
      class="mx-auto flex max-w-md flex-col gap-3 sm:flex-row"
    >
      <input
        type="email"
        name="email"
        required
        placeholder="your@email.com"
        class="flex-1 rounded-md border border-border bg-background px-4 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
      />
      <button
        type="submit"
        class={buttonVariants({ variant: 'default' })}
      >
        Notify me
      </button>
    </form>
  </section>
</Layout>
